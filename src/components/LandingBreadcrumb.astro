---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="landing-bc" aria-label="Percorso di navigazione">
  <div class="container">
    <ol>
      {items.map((crumb, i) => (
        <li>
          {crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}
        </li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .landing-bc {
    padding: 16px 0 0;
    font-size: 0.88rem;
    color: var(--color-muted);
  }
  .landing-bc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .landing-bc li:not(:last-child)::after {
    content: "/";
    margin-left: 6px;
    color: var(--color-border);
    font-weight: 400;
  }
  .landing-bc a {
    color: var(--color-primary);
    font-weight: 600;
  }
  .landing-bc a:hover {
    text-decoration: underline;
  }
</style>

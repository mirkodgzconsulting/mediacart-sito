---
import Base from "../layouts/Base.astro";
---

<Base
  title="Partner | MEDIA Cart Milano"
  description="Partner di MEDIA Cart a Milano: riferimenti principali del nostro ecosistema stampa."
  path="/partner"
>
  <section class="section">
    <div class="container">
      <h1>Partner</h1>
      <p class="lead">
        Collaboriamo con partner selezionati per offrire continuita operativa e standard elevati nel settore stampa.
      </p>
      <div class="grid-3">
        <article class="card">
          <div class="logo-wrap">
            <img
              src="/images/Stampelowcost-Logopng.png"
              alt="Logo StampeLowCost"
              loading="lazy"
            />
          </div>
          <h2>StampeLowCost</h2>
          <p class="muted">Partner principale.</p>
          <p><a href="https://print.stampelowcost.com/" target="_blank" rel="noopener noreferrer">Vai al sito</a></p>
        </article>
        <article class="card">
          <div class="logo-wrap">
            <img src="/images/logo-mediaprint-centrostampa.svg" alt="Logo Media Print Centro Stampa" loading="lazy" />
          </div>
          <h2>Centrostampa</h2>
          <p class="muted">Partner operativo.</p>
          <p><a href="https://centrostampa.srl/" target="_blank" rel="noopener noreferrer">Vai al sito</a></p>
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .logo-wrap {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #fff;
    min-height: 94px;
    padding: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .logo-wrap img {
    max-height: 64px;
    width: auto;
    object-fit: contain;
  }
</style>
